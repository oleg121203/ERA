{
    "name": "ERA Development",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12",
            "installTools": true,
            "installPytest": true,
            "installPylint": true
        },
        "ghcr.io/devcontainers/features/git:1": {
            "version": "latest",
            "ppa": true
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts",
            "nodeGypDependencies": true
        }
    },

    "postCreateCommand": "if [ ! -d /workspaces/ERA ]; then mkdir -p /workspaces/ERA; fi && touch /workspaces/ERA/.env && chmod 666 /workspaces/ERA/.env && touch /workspaces/project-structure.txt && chmod 666 /workspaces/project-structure.txt && chown -R node:node /workspaces/ERA && git config --global user.name 'Kizyma Oleg' && git config --global user.email 'oleg1203@gmail.com' && npm install -g ts-node typescript && npm install --no-scripts",

    "postStartCommand": "bash -c '. ~/.bashrc && bash ./scripts/setup-env.sh || true && npm run verify-dependencies || true && npm run watch-structure || true' && nohup code-server --bind-addr 0.0.0.0:4580 --auth none /workspaces/ERA &",

    "initializeCommand": {
        "set-permissions": "mkdir -p ${localWorkspaceFolder} && touch ${localWorkspaceFolder}/.env && chmod 666 ${localWorkspaceFolder}/.env && touch ${localWorkspaceFolder}/project-structure.txt && chmod 666 ${localWorkspaceFolder}/project-structure.txt"
    },

    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.fixAll": "explicit",
                    "source.organizeImports": "explicit"
                },
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    }
                },
                "[typescript]": {
                    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
                    "editor.formatOnSave": true
                },
                "[javascript]": {
                    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.fixAll.eslint": "explicit"
                    }
                },
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.linting.flake8Enabled": true,
                "python.linting.mypyEnabled": true,
                "python.sortImports.args": ["--profile", "black"],
                "python.formatting.blackPath": "black",
                "python.formatting.blackArgs": ["--line-length", "88"],
                "isort.args": [
                    "--profile",
                    "black",
                    "--line-length",
                    "88"
                ],
                "isort.check": true,
                "python.formatting.autopep8Path": "none",
                "[javascriptreact]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode",
                    "editor.formatOnSave": true
                },
                "[typescriptreact]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode",
                    "editor.formatOnSave": true
                },
                "eslint.format.enable": true,
                "python.formatting.provider": "none",
                "editor.defaultFormatter": "dbaeumer.vscode-eslint",
                "files.autoSave": "afterDelay",
                "files.autoSaveDelay": 5000,
                "eslint.enable": true,
                "eslint.run": "onType",
                "eslint.lintTask.enable": true,
                "eslint.codeActionsOnSave.mode": "all",
                "eslint.alwaysShowStatus": true,
                "eslint.debug": true,
                "eslint.packageManager": "npm",
                "eslint.probe": [
                    "javascript",
                    "typescript",
                    "javascriptreact",
                    "typescriptreact"
                ],
                "eslint.quiet": false,
                "eslint.validate": [
                    "javascript",
                    "javascriptreact",
                    "typescript",
                    "typescriptreact"
                ],
                "eslint.options": {
                    "configFile": "/workspaces/ERA/config/.eslintrc.js"
                },
                "prettier.configPath": "/workspaces/ERA/config/.prettierrc.js",
                "npm.packageManager": "npm",
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.shell.linux": "/bin/bash",
                "git.enableSmartCommit": true,
                "files.eol": "\n",
                "files.exclude": {
                    "**/.git": true,
                    "**/.svn": true,
                    "**/.hg": true,
                    "**/CVS": true,
                    "**/.DS_Store": true,
                    "**/node_modules": true
                },
                "files.watcherExclude": {
                    "**/.git/**": true,
                    "**/node_modules/**": true,
                    "**/bower_components/**": true
                },
                "readonly.files": [
                    "**/node_modules/**",
                    "**/.git/**"
                ],
                "geminiCodeAssist.apiKey": "${env:GEMINI_API_KEY}"
            },
            "extensions": [
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "ms-python.python",
                "ms-python.black-formatter",
                "ms-python.autopep8",
                "ms-python.flake8",
                "ms-python.isort",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "google.geminicodeassist",
                "eamodio.gitlens",
                "christian-kohler.path-intellisense",
                "visualstudioexptteam.vscodeintellicode",
                "ms-azuretools.vscode-docker",
                "swagatachaudhuri.github-copilot-tools-pack",
                "github.copilot-workspace",
                "gemini.code-assist",
                "Continue.continue",
                "ms-python.debugpy"
            ]
        }
    },

    "workspaceFolder": "/workspaces/ERA",

    "mounts": [
        "source=${localWorkspaceFolder},target=/workspaces/ERA,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached,readonly"
    ],

    "remoteUser": "node",
    "updateRemoteUserUID": true,

    "portsAttributes": {
        "3000": {
            "label": "Local Development",
            "onAutoForward": "notify",
            "protocol": "http"
        },
        "4580": {
            "label": "Remote Access",
            "onAutoForward": "notify",
            "protocol": "http",
            "visibility": "public"
        }
    },
    "forwardPorts": [3000, 4580],
    "remoteEnv": {
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
    }
}